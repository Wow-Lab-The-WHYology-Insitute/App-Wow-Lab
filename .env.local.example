# Copy to .env.local (gitignored) and fill in real values — never commit actual secrets.

# Public — safe in the browser bundle. RLS is what keeps this safe.
NEXT_PUBLIC_SUPABASE_URL=https://dbchdbxojeczjglugbhe.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Used to build magic-link/invite redirect URLs. Must be in
# supabase/config.toml's [auth] additional_redirect_urls (or already covered
# by an existing entry there).
# Local dev:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Once Vercel/app.wowlab.ro is linked, production should use:
# NEXT_PUBLIC_SITE_URL=https://app.wowlab.ro

# SERVICE_ROLE — server-only, privileged, bypasses RLS. Never NEXT_PUBLIC_*,
# never referenced outside lib/supabase-admin.ts. Set this in Vercel's
# server-only environment variables, never in a client-reachable context.
SUPABASE_SERVICE_ROLE_KEY=
